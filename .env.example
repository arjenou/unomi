# Copy to .env.local for local `vercel dev` (do not commit real secrets)

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# 可选：除 hby@unomi-jp.com 外需要抄送的地址（逗号分隔）
# SEMINAR_NOTIFY_CC=ops@example.com

# 仅在 Vercel 上默认「先 202 再后台发信」。设为 true 可强制同步发信（便于排查 SMTP）
# SEMINAR_MAIL_SYNC=true

# Optional: restrict CORS (comma-separated). If empty, allows unomi-jp.com and *.vercel.app previews.
# SEMINAR_ALLOWED_ORIGINS=https://www.unomi-jp.com
