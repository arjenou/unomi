# Copy to .env.local for local `vercel dev` (do not commit real secrets)

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

SEMINAR_NOTIFY_TO=HBY@unomi-jp.com
# Optional: restrict CORS (comma-separated). If empty, allows unomi-jp.com and *.vercel.app previews.
# SEMINAR_ALLOWED_ORIGINS=https://www.unomi-jp.com
